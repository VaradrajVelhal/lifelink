# Copy this file to .env and fill in the values before running the server.

# Django secret key — generate a strong random value for production
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (e.g. localhost,127.0.0.1)
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL database settings
DB_NAME=lifelink
DB_USER=lifelink_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
